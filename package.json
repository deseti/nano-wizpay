{
  "name": "nano-wizpay",
  "version": "0.1.0",
  "description": "WizPay Nano — USDC pay-per-call API for AI agents on Arc",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "agent:treasury": "tsx src/agents/treasury.ts",
    "agent:payroll": "tsx src/agents/payroll.ts",
    "demo:swap-real": "bash scripts/demo-swap-real.sh",
    "demo:payroll-real": "bash scripts/demo-payroll-fallback-real.sh"
  },
  "keywords": [
    "arc",
    "circle",
    "usdc",
    "x402",
    "agents",
    "lepton-hackathon"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pino-pretty": "^11.2.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.18.2"
  }
}
