# =========================================
# WizPay Nano — env template
# =========================================
# Copy to .env and fill in. NEVER commit .env.

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Arc Testnet (Canteen-hosted RPC)
ARC_RPC_URL=https://rpc.arc-testnet.canteen.network
ARC_CHAIN_ID=5042001
USDC_CONTRACT=0x3600000000000000000000000000000000000000

# Server wallet (receives USDC payments)
SERVER_WALLET_PRIVATE_KEY=

# Settlement config
SETTLEMENT_MODE=arc_testnet
MIN_PAYMENT_USDC=0.0001

# LLM (for agent layer — Phase 3)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# x402 config
X402_FACILITATOR_URL=
X402_NETWORK=arc-testnet
